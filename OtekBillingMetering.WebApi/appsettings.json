{
  "AllowedHosts": "*",
  "Observability": {
    "ServiceName": "OtekBillingMetering.Api",
    "ServiceVersion": "9.0.0",
    "Environment": "production",
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableRuntimeInstrumentation": false,
    "OtlpEndpoint": "http://otel-collector:4317",
    "TraceSamplingRatio": 0.1
  },
  "LoggingBehavior": {
    "LogStartEndAsInformation": true,
    "SlowRequestThresholdMs": 1000
  },
  "Serilog": {
    "MinimumLevel": "Information"
  }
}
